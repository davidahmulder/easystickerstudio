  #sticker-designer-embed .sde-title {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 700;
  }

  #sticker-designer-embed .sde-top-actions,
  #sticker-designer-embed .sde-toolbar {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
