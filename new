<script>
  (function () {
    var root = document.getElementById("sticker-designer-embed");
    if (!root || root.dataset.ready === "true") return;
    root.dataset.ready = "true";

    function startWhenReady() {
      if (!window.fabric) {
        window.setTimeout(startWhenReady, 80);
        return;
      }
      initStickerDesigner();
    }

    function initStickerDesigner() {
      var ui = function (name) {
        return root.querySelector('[data-sde="' + name + '"]');
      };
      var all = function (selector) {
        return Array.prototype.slice.call(root.querySelectorAll(selector));
      };

      var canvas = new fabric.Canvas(ui("canvas"), {
        preserveObjectStacking: true,
        backgroundColor: "rgba(255,255,255,0)"
      });

      fabric.Object.prototype.cornerColor = "#0f9f8f";
      fabric.Object.prototype.cornerStrokeColor = "#ffffff";
      fabric.Object.prototype.borderColor = "#0f9f8f";
      fabric.Object.prototype.cornerSize = 12;
      fabric.Object.prototype.transparentCorners = false;
      fabric.Object.prototype.borderScaleFactor = 1.4;

      var activeObject = null;
      var history = [];
      var historyIndex = -1;
      var ignoreHistory = false;
      var objectCounter = 1;
      var historyTimer = null;
      var editorHasFocus = false;
      var presets = {
        fresh: { fill: "#0f9f8f", stroke: "#ffffff", shadow: true },
        bold: { fill: "#17212f", stroke: "#f7b731", shadow: true },
        pop: { fill: "#e8497e", stroke: "#ffffff", shadow: true },
        mono: { fill: "#ffffff", stroke: "#111827", shadow: false }
      };

      root.stickerDesignerCanvas = canvas;

      function refreshIcons() {
        if (window.lucide) {
          window.lucide.createIcons({
            attrs: { width: 18, height: 18, strokeWidth: 2.2 }
          });
        }
      }

      function isText(object) {
        return object && (object.type === "textbox" || object.type === "i-text" || object.type === "text");
      }

      function objectKind(object) {
        if (!object) return "Object";
        if (isText(object)) return "Text";
        if (object.type === "image") return "Image";
        if (object.type === "circle") return "Circle";
        if (object.type === "polygon") return "Star";
        return "Shape";
      }

      function iconFor(object) {
        if (isText(object)) return "type";
        if (object.type === "image") return "image";
        if (object.type === "circle") return "circle";
        if (object.type === "polygon") return "star";
        return "square";
      }

      function escapeHtml(value) {
        return String(value)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      }

      function identify(object, type) {
        object.set({
          id: object.id || "sde-object-" + Date.now() + "-" + objectCounter,
          name: object.name || type + " " + objectCounter
        });
        objectCounter += 1;
        return object;
      }

      function saveHistoryNow() {
        if (ignoreHistory) return;
        history = history.slice(0, historyIndex + 1);
        history.push(JSON.stringify(canvas.toJSON(["id", "name"])));
        historyIndex = history.length - 1;
        updateHistoryButtons();
      }

      function scheduleHistory() {
        if (ignoreHistory) return;
        window.clearTimeout(historyTimer);
        historyTimer = window.setTimeout(saveHistoryNow, 120);
      }

      function loadHistory(index) {
        if (index < 0 || index >= history.length) return;
        ignoreHistory = true;
        canvas.loadFromJSON(history[index], function () {
          canvas.renderAll();
          activeObject = canvas.getActiveObject();
          ignoreHistory = false;
          updateUI();
          updateHistoryButtons();
        });
      }

      function updateHistoryButtons() {
        root.querySelector('[data-action="undo"]').disabled = historyIndex <= 0;
        root.querySelector('[data-action="redo"]').disabled = historyIndex >= history.length - 1;
      }

      function addText(text, options) {
        options = options || {};
        var textbox = new fabric.Textbox(text || "New text", {
          left: options.left || 290,
          top: options.top || 220,
          width: options.width || 400,
          fontSize: options.fontSize || 64,
          fontFamily: options.fontFamily || "Montserrat",
          fontWeight: options.fontWeight || 700,
          fill: options.fill || "#111827",
          textAlign: options.textAlign || "center",
          stroke: options.stroke || "",
          strokeWidth: options.strokeWidth || 0,
          paintFirst: "stroke",
          shadow: options.shadow || null,
          padding: 8,
          lineHeight: 0.95
        });
        identify(textbox, "Text");
        canvas.add(textbox);
        canvas.setActiveObject(textbox);
        activeObject = textbox;
        canvas.requestRenderAll();
        updateUI();
      }

      function starPoints(outerRadius, innerRadius, points) {
        var result = [];
        var step = Math.PI / points;
        for (var i = 0; i < points * 2; i += 1) {
          var radius = i % 2 === 0 ? outerRadius : innerRadius;
          var angle = i * step - Math.PI / 2;
          result.push({
            x: outerRadius + Math.cos(angle) * radius,
            y: outerRadius + Math.sin(angle) * radius
          });
        }
        return result;
      }

      function addShape(type) {
        var shape;
        if (type === "circle") {
          shape = new fabric.Circle({
            left: 365,
            top: 150,
            radius: 110,
            fill: "#ff6b4a",
            stroke: "#ffffff",
            strokeWidth: 10,
            shadow: new fabric.Shadow({ color: "rgba(23,33,47,0.18)", blur: 18, offsetX: 0, offsetY: 8 })
          });
          identify(shape, "Circle");
        }
        if (type === "rounded") {
          shape = new fabric.Rect({
            left: 310,
            top: 190,
            width: 360,
            height: 150,
            rx: 26,
            ry: 26,
            fill: "#0f9f8f",
            stroke: "#ffffff",
            strokeWidth: 10,
            shadow: new fabric.Shadow({ color: "rgba(23,33,47,0.18)", blur: 18, offsetX: 0, offsetY: 8 })
          });
          identify(shape, "Shape");
        }
        if (type === "star") {
          shape = new fabric.Polygon(starPoints(110, 52, 5), {
            left: 390,
            top: 160,
            fill: "#f7b731",
            stroke: "#ffffff",
            strokeWidth: 10,
            shadow: new fabric.Shadow({ color: "rgba(23,33,47,0.18)", blur: 18, offsetX: 0, offsetY: 8 })
          });
          identify(shape, "Star");
        }
        if (!shape) return;
        canvas.add(shape);
        if (type === "circle" || type === "rounded") canvas.sendToBack(shape);
        canvas.setActiveObject(shape);
        activeObject = shape;
        canvas.requestRenderAll();
        updateUI();
      }

      function uploadImage(event) {
        var file = event.target.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function (fileEvent) {
          fabric.Image.fromURL(fileEvent.target.result, function (img) {
            img.set({ left: 250, top: 120, shadow: null });
            img.scaleToWidth(Math.min(420, img.width || 420));
            identify(img, "Image");
            canvas.add(img);
            canvas.setActiveObject(img);
            activeObject = img;
            canvas.requestRenderAll();
            updateUI();
          }, { crossOrigin: "anonymous" });
        };
        reader.readAsDataURL(file);
        event.target.value = "";
      }

      function updateOutlineValue() {
        ui("outlineValue").textContent = ui("outlineWidth").value + " px";
      }

      function setFill(color) {
        if (!activeObject) return;
        ui("fill").value = color;
        if (activeObject.type !== "image") activeObject.set({ fill: color });
        canvas.requestRenderAll();
        scheduleHistory();
        updateUI();
      }

      function setOutline(color) {
        ui("outlineColor").value = color;
        applyOutline();
      }

      function applyOutline() {
        updateOutlineValue();
        if (!activeObject || activeObject.type === "image") return;
        activeObject.set({
          stroke: ui("outlineColor").value,
          strokeWidth: Number(ui("outlineWidth").value),
          paintFirst: "stroke"
        });
        canvas.requestRenderAll();
        scheduleHistory();
        updateUI();
      }

      function applyShadow() {
        if (!activeObject) return;
        activeObject.set({
          shadow: ui("shadow").checked
            ? new fabric.Shadow({ color: "rgba(23,33,47,0.24)", blur: 18, offsetX: 0, offsetY: 10 })
            : null
        });
        canvas.requestRenderAll();
        scheduleHistory();
        updateUI();
      }

      function makeSticker() {
        if (!activeObject) return;
        if (activeObject.type === "image") {
          activeObject.set({
            shadow: new fabric.Shadow({
              color: ui("outlineColor").value,
              blur: Math.max(10, Number(ui("outlineWidth").value)),
              offsetX: 0,
              offsetY: 0
            })
          });
        } else {
          applyOutline();
          applyShadow();
        }
        activeObject.setCoords();
        canvas.requestRenderAll();
        scheduleHistory();
        updateUI();
      }

      function changeFont() {
        if (!isText(activeObject)) return;
        var font = ui("font").value;
        var apply = function () {
          activeObject.set({ fontFamily: font });
          activeObject.setCoords();
          canvas.requestRenderAll();
          scheduleHistory();
          updateUI();
        };
        if (document.fonts && document.fonts.load) {
          document.fonts.load('40px "' + font + '"').then(apply);
        } else {
          apply();
        }
      }

      function changeSize(value) {
        if (!isText(activeObject)) return;
        var size = Math.max(8, Math.min(220, Number(value) || 8));
        ui("size").value = size;
        ui("sizeNumber").value = size;
        ui("sizeValue").textContent = size;
        activeObject.set({ fontSize: size });
        activeObject.setCoords();
        canvas.requestRenderAll();
        scheduleHistory();
      }

      function changeOpacity() {
        if (!activeObject) return;
        var opacity = Number(ui("opacity").value) / 100;
        ui("opacityValue").textContent = Math.round(opacity * 100) + "%";
        activeObject.set({ opacity: opacity });
        canvas.requestRenderAll();
        scheduleHistory();
      }

      function applyPreset(name) {
        if (!activeObject || !presets[name]) return;
        var preset = presets[name];
        ui("fill").value = preset.fill;
        ui("outlineColor").value = preset.stroke;
        ui("shadow").checked = preset.shadow;
        if (activeObject.type !== "image") {
          activeObject.set({
            fill: preset.fill,
            stroke: preset.stroke,
            strokeWidth: Number(ui("outlineWidth").value),
            paintFirst: "stroke"
          });
        }
        applyShadow();
        canvas.requestRenderAll();
        scheduleHistory();
        updateUI();
      }

      function duplicateObject() {
        if (!activeObject) return;
        activeObject.clone(function (clone) {
          clone.set({
            left: (activeObject.left || 0) + 28,
            top: (activeObject.top || 0) + 28,
            id: null,
            name: null
          });
          identify(clone, objectKind(clone));
          canvas.add(clone);
          canvas.setActiveObject(clone);
          activeObject = clone;
          canvas.requestRenderAll();
          updateUI();
        }, ["id", "name"]);
      }

      function deleteObject() {
        var selected = canvas.getActiveObject();
        if (!selected) return;
        canvas.remove(selected);
        canvas.discardActiveObject();
        activeObject = null;
        canvas.requestRenderAll();
        updateUI();
      }

      function clearCanvas() {
        canvas.getObjects().forEach(function (object) {
          canvas.remove(object);
        });
        activeObject = null;
        canvas.requestRenderAll();
        updateUI();
      }

      function saveToCart() {
        canvas.discardActiveObject();
        canvas.renderAll();

        var cartKey = "stickerDesignerCart";
        var cart = [];
        var cartItem = {
          id: "sticker-" + Date.now(),
          createdAt: new Date().toISOString(),
          preview: canvas.toDataURL({ format: "png", multiplier: 2, enableRetinaScaling: true }),
          design: canvas.toJSON(["id", "name"]),
          width: canvas.getWidth(),
          height: canvas.getHeight()
        };

        try {
          cart = JSON.parse(window.localStorage.getItem(cartKey) || "[]");
          if (!Array.isArray(cart)) cart = [];
        } catch (error) {
          cart = [];
        }

        cart.push(cartItem);
        try {
          window.localStorage.setItem(cartKey, JSON.stringify(cart));
          cartItem.savedToStorage = true;
        } catch (error) {
          cartItem.savedToStorage = false;
        }

        root.dispatchEvent(new CustomEvent("sticker-designer:add-to-cart", {
          bubbles: true,
          detail: cartItem
        }));

        var cartButton = root.querySelector('[data-action="cart"]');
        var originalText = cartButton.innerHTML;
        cartButton.innerHTML = '<i data-lucide="check"></i>Added';
        refreshIcons();
        window.setTimeout(function () {
          cartButton.innerHTML = originalText;
          refreshIcons();
        }, 1600);

        updateUI();
      }

      function renderLayers() {
        var container = ui("layers");
        var objects = canvas.getObjects().slice().reverse();
        container.innerHTML = "";
        if (!objects.length) {
          var empty = document.createElement("span");
          empty.className = "sde-layer-meta";
          empty.textContent = "No layers";
          container.appendChild(empty);
          return;
        }
        objects.forEach(function (object) {
          var button = document.createElement("button");
          button.type = "button";
          button.className = "sde-layer-button" + (object === activeObject ? " is-active" : "");
          button.innerHTML =
            '<i data-lucide="' + iconFor(object) + '"></i><span><span class="sde-layer-label">' +
            escapeHtml(object.name || objectKind(object)) +
            '</span><span class="sde-layer-meta">' +
            objectKind(object) +
            "</span></span>";
          button.addEventListener("click", function () {
            canvas.setActiveObject(object);
            activeObject = object;
            canvas.requestRenderAll();
            updateUI();
          });
          container.appendChild(button);
        });
        refreshIcons();
      }

      function updateInspector() {
        var hasSelection = Boolean(activeObject);
        var textSelected = isText(activeObject);
        all("[data-text-control]").forEach(function (control) {
          control.classList.toggle("sde-hidden", !textSelected);
        });

        if (!hasSelection) {
          ui("opacity").value = 100;
          ui("opacityValue").textContent = "100%";
          return;
        }

        if (textSelected) {
          ui("font").value = activeObject.fontFamily || "Montserrat";
          ui("size").value = activeObject.fontSize || 64;
          ui("sizeNumber").value = activeObject.fontSize || 64;
          ui("sizeValue").textContent = activeObject.fontSize || 64;
        }

        if (activeObject.fill && typeof activeObject.fill === "string" && activeObject.fill.indexOf("#") === 0) {
          ui("fill").value = activeObject.fill;
        }
        if (activeObject.stroke && typeof activeObject.stroke === "string" && activeObject.stroke.indexOf("#") === 0) {
          ui("outlineColor").value = activeObject.stroke;
        }

        ui("outlineWidth").value = Math.round(activeObject.strokeWidth || Number(ui("outlineWidth").value) || 0);
        updateOutlineValue();
        ui("opacity").value = Math.round((activeObject.opacity == null ? 1 : activeObject.opacity) * 100);
        ui("opacityValue").textContent = ui("opacity").value + "%";
        ui("shadow").checked = Boolean(activeObject.shadow);
      }

      function updateUI() {
        activeObject = canvas.getActiveObject();
        updateHistoryButtons();
        updateInspector();
        renderLayers();
        ui("objectCount").textContent = String(canvas.getObjects().length);
        ui("activeName").textContent = activeObject ? activeObject.name || objectKind(activeObject) : "Nothing selected";
      }

      root.addEventListener("click", function (event) {
        var actionButton = event.target.closest("[data-action]");
        if (actionButton && root.contains(actionButton)) {
          var action = actionButton.getAttribute("data-action");
          if (action === "text") addText();
          if (action === "upload") ui("upload").click();
          if (action === "circle") addShape("circle");
          if (action === "rounded") addShape("rounded");
          if (action === "star") addShape("star");
          if (action === "undo" && historyIndex > 0) loadHistory(--historyIndex);
          if (action === "redo" && historyIndex < history.length - 1) loadHistory(++historyIndex);
          if (action === "front" && activeObject) { canvas.bringForward(activeObject); canvas.requestRenderAll(); scheduleHistory(); updateUI(); }
          if (action === "back" && activeObject) { canvas.sendBackwards(activeObject); canvas.requestRenderAll(); scheduleHistory(); updateUI(); }
          if (action === "duplicate") duplicateObject();
          if (action === "delete") deleteObject();
          if (action === "sticker") makeSticker();
          if (action === "center" && activeObject) { canvas.centerObject(activeObject); activeObject.setCoords(); canvas.requestRenderAll(); scheduleHistory(); updateUI(); }
          if (action === "clear") clearCanvas();
          if (action === "cart") saveToCart();
        }

        var presetButton = event.target.closest("[data-preset]");
        if (presetButton && root.contains(presetButton)) {
          applyPreset(presetButton.getAttribute("data-preset"));
        }

        var swatch = event.target.closest(".sde-swatch");
        if (swatch && root.contains(swatch)) {
          var group = swatch.closest("[data-swatch-group]").getAttribute("data-swatch-group");
          if (group === "fill") setFill(swatch.getAttribute("data-color"));
          if (group === "outline") setOutline(swatch.getAttribute("data-color"));
        }
      });

      root.addEventListener("pointerdown", function () {
        editorHasFocus = true;
      });

      document.addEventListener("pointerdown", function (event) {
        if (!root.contains(event.target)) editorHasFocus = false;
      });

      ui("upload").addEventListener("change", uploadImage);
      ui("font").addEventListener("change", changeFont);
      ui("size").addEventListener("input", function () { changeSize(ui("size").value); });
      ui("sizeNumber").addEventListener("input", function () { changeSize(ui("sizeNumber").value); });
      ui("fill").addEventListener("input", function () { setFill(ui("fill").value); });
      ui("opacity").addEventListener("input", changeOpacity);
      ui("outlineWidth").addEventListener("input", applyOutline);
      ui("outlineColor").addEventListener("input", applyOutline);
      ui("shadow").addEventListener("change", applyShadow);

      canvas.on("object:added", scheduleHistory);
      canvas.on("object:modified", scheduleHistory);
      canvas.on("object:removed", scheduleHistory);
      canvas.on("selection:created", updateUI);
      canvas.on("selection:updated", updateUI);
      canvas.on("selection:cleared", updateUI);
      canvas.on("mouse:dblclick", function (event) {
        if (isText(event.target)) {
          canvas.setActiveObject(event.target);
          event.target.enterEditing();
          event.target.selectAll();
        }
      });

      document.addEventListener("keydown", function (event) {
        var selected = canvas.getActiveObject();
        if (!selected || (!editorHasFocus && !root.contains(document.activeElement))) return;
        if (isText(selected) && selected.isEditing) return;
        if (event.key === "Delete" || event.key === "Backspace") {
          event.preventDefault();
          deleteObject();
        }
        if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "d") {
          event.preventDefault();
          duplicateObject();
        }
        if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "z") {
          event.preventDefault();
          if (event.shiftKey && historyIndex < history.length - 1) {
            historyIndex += 1;
            loadHistory(historyIndex);
          } else if (!event.shiftKey && historyIndex > 0) {
            historyIndex -= 1;
            loadHistory(historyIndex);
          }
        }
      });

      ignoreHistory = true;
      addText("STICKER", {
        left: 310,
        top: 210,
        width: 360,
        fontSize: 72,
        fontFamily: "Bangers",
        fill: "#111827",
        textAlign: "center",
        stroke: "#ffffff",
        strokeWidth: 10,
        shadow: new fabric.Shadow({ color: "rgba(23,33,47,0.22)", blur: 16, offsetX: 0, offsetY: 10 })
      });
      ignoreHistory = false;
      saveHistoryNow();
      updateUI();
      refreshIcons();
    }
    
    

   




    startWhenReady();
  })();
</script>
