  #sticker-designer-embed .sde-side {
    border-right: 1px solid var(--sde-line);
  }

  #sticker-designer-embed .sde-inspector {
    border-left: 1px solid var(--sde-line);
  }

  #sticker-designer-embed .sde-section {
    padding: 18px;
    border-bottom: 1px solid var(--sde-line);
  }

  #sticker-designer-embed .sde-section:last-child {
    border-bottom: 0;
  }

  #sticker-designer-embed .sde-section-title {
    margin: 0 0 12px;
    color: var(--sde-muted);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  #sticker-designer-embed .sde-tool-list,
  #sticker-designer-embed .sde-control-stack,
  #sticker-designer-embed .sde-layers {
    display: grid;
    gap: 10px;
  }

  #sticker-designer-embed .sde-tool-button {
    width: 100%;
    justify-content: flex-start;
    padding: 12px;
    color: var(--sde-text);
    background: var(--sde-panel-soft);
    border: 1px solid var(--sde-line);
    font-weight: 700;
  }

  #sticker-designer-embed .sde-preset-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  #sticker-designer-embed .sde-preset {
    display: grid;
    min-height: 72px;
    padding: 10px;
    border: 1px solid var(--sde-line);
    border-radius: 8px;
    background: var(--sde-panel-soft);
    color: var(--sde-text);
    text-align: left;
    align-content: end;
    position: relative;
    overflow: hidden;
    font-weight: 700;
  }

  #sticker-designer-embed .sde-preset:before {
    content: "";
    position: absolute;
    inset: 9px 9px auto auto;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--sde-preset-a);
    box-shadow: -18px 20px 0 var(--sde-preset-b);
  }

  #sticker-designer-embed .sde-canvas-zone {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    min-width: 0;
    min-height: 0;
    background:
      linear-gradient(90deg, rgba(217, 224, 232, 0.58) 1px, transparent 1px),
      linear-gradient(rgba(217, 224, 232, 0.58) 1px, transparent 1px),
      #edf1f4;
    background-size: 34px 34px;
  }

  #sticker-designer-embed .sde-contextbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 50px;
    gap: 12px;
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.9);
    border-bottom: 1px solid var(--sde-line);
    backdrop-filter: blur(14px);
  }

  #sticker-designer-embed .sde-selection {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
    color: var(--sde-muted);
    font-size: 13px;
    font-weight: 700;
  }

  #sticker-designer-embed .sde-selection strong {
    color: var(--sde-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  #sticker-designer-embed .sde-stage {
    display: grid;
    min-width: 0;
    min-height: 0;
    overflow: auto;
    padding: 36px;
    place-items: center;
  }

  #sticker-designer-embed .sde-artboard-wrap {
    padding: 18px;
    background: #ffffff;
    border: 1px solid var(--sde-line-strong);
    border-radius: 8px;
    box-shadow: var(--sde-shadow);
  }

  #sticker-designer-embed .sde-artboard {
    position: relative;
    width: 980px;
    height: 560px;
    overflow: hidden;
    background-color: #ffffff;
    background-image:
      linear-gradient(45deg, #e9edf2 25%, transparent 25%),
      linear-gradient(-45deg, #e9edf2 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #e9edf2 75%),
      linear-gradient(-45deg, transparent 75%, #e9edf2 75%);
    background-position: 0 0, 0 10px, 10px -10px, -10px 0;
    background-size: 20px 20px;
  }

  #sticker-designer-embed .canvas-container,
  #sticker-designer-embed canvas {
    display: block;
  }

  #sticker-designer-embed .sde-field {
    display: grid;
    gap: 8px;
  }

  #sticker-designer-embed .sde-field-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 10px;
  }

  #sticker-designer-embed .sde-field label,
  #sticker-designer-embed .sde-field-row label,
  #sticker-designer-embed .sde-toggle span {
    color: var(--sde-muted);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  #sticker-designer-embed .sde-field input[type="number"],
  #sticker-designer-embed .sde-field select {
    width: 100%;
    min-height: 38px;
    border: 1px solid var(--sde-line);
    border-radius: 8px;
    padding: 0 10px;
    color: var(--sde-text);
    background: var(--sde-panel-soft);
    outline: none;
  }

  #sticker-designer-embed .sde-field input[type="number"]:focus,
  #sticker-designer-embed .sde-field select:focus {
    border-color: var(--sde-accent);
    box-shadow: 0 0 0 4px var(--sde-focus);
  }

  #sticker-designer-embed .sde-range-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 54px;
    align-items: center;
    gap: 10px;
  }

  #sticker-designer-embed input[type="range"] {
    width: 100%;
    accent-color: var(--sde-accent);
  }

  #sticker-designer-embed .sde-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 30px;
    border-radius: 8px;
    background: var(--sde-panel-soft);
    color: var(--sde-muted);
    font-size: 12px;
    font-weight: 700;
  }

  #sticker-designer-embed .sde-color-row {
    display: grid;
    grid-template-columns: 40px minmax(0, 1fr);
    align-items: center;
    gap: 10px;
  }

  #sticker-designer-embed input[type="color"] {
    width: 40px;
    height: 38px;
    padding: 2px;
    border: 1px solid var(--sde-line);
    border-radius: 8px;
    background: #ffffff;
  }

  #sticker-designer-embed .sde-swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  #sticker-designer-embed .sde-swatch {
    width: 24px;
    height: 24px;
    border: 1px solid rgba(23, 33, 47, 0.18);
    border-radius: 50%;
    background: var(--sde-swatch);
  }

  #sticker-designer-embed .sde-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  #sticker-designer-embed .sde-switch {
    position: relative;
    width: 46px;
    height: 26px;
    flex: 0 0 auto;
  }

  #sticker-designer-embed .sde-switch input {
    position: absolute;
    inset: 0;
    opacity: 0;
  }

  #sticker-designer-embed .sde-switch span {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: #d4dbe4;
    transition: background 140ms ease;
  }

  #sticker-designer-embed .sde-switch span:before {
    content: "";
    position: absolute;
    top: 3px;
    left: 3px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #ffffff;
    box-shadow: 0 2px 6px rgba(23, 33, 47, 0.2);
    transition: transform 140ms ease;
  }

  #sticker-designer-embed .sde-switch input:checked + span {
    background: var(--sde-accent);
  }

  #sticker-designer-embed .sde-switch input:checked + span:before {
    transform: translateX(20px);
  }

  #sticker-designer-embed .sde-layer-button {
    width: 100%;
    justify-content: flex-start;
    min-width: 0;
    padding: 10px;
    color: var(--sde-text);
    background: var(--sde-panel-soft);
    border: 1px solid var(--sde-line);
    text-align: left;
  }

  #sticker-designer-embed .sde-layer-button.is-active {
    border-color: var(--sde-accent);
    box-shadow: inset 3px 0 0 var(--sde-accent);
  }

  #sticker-designer-embed .sde-layer-label {
    display: block;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 13px;
    font-weight: 700;
  }

  #sticker-designer-embed .sde-layer-meta {
    display: block;
    color: var(--sde-muted);
    font-size: 11px;
  }

  #sticker-designer-embed .sde-status {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 0 18px;
    color: var(--sde-muted);
    background: var(--sde-panel);
    border-top: 1px solid var(--sde-line);
    font-size: 12px;
    font-weight: 700;
  }

  #sticker-designer-embed .sde-hidden {
    display: none !important;
  }

  @media (max-width: 1100px) {
    #sticker-designer-embed {
      height: 820px;
    }

    #sticker-designer-embed .sde-workspace {
      grid-template-columns: 84px minmax(0, 1fr);
    }

    #sticker-designer-embed .sde-side .sde-section {
      padding: 12px;
    }

    #sticker-designer-embed .sde-side .sde-section-title,
    #sticker-designer-embed .sde-side .sde-tool-button strong,
    #sticker-designer-embed .sde-preset-grid,
    #sticker-designer-embed .sde-toolbar.sde-hide-medium {
      display: none;
    }

    #sticker-designer-embed .sde-tool-button {
      justify-content: center;
      width: 48px;
      min-height: 48px;
      padding: 0;
    }

    #sticker-designer-embed .sde-inspector {
      grid-column: 1 / -1;
      max-height: 300px;
      border-top: 1px solid var(--sde-line);
      border-left: 0;
    }

    #sticker-designer-embed .sde-topbar {
      grid-template-columns: minmax(150px, 1fr) auto;
    }

    #sticker-designer-embed .sde-top-actions {
      justify-content: flex-end;
    }
  }

  @media (max-width: 760px) {
    #sticker-designer-embed {
      height: 940px;
    }

    #sticker-designer-embed .sde-shell {
      grid-template-rows: auto minmax(0, 1fr) auto;
    }

    #sticker-designer-embed .sde-topbar {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 12px;
    }

    #sticker-designer-embed .sde-top-actions {
      justify-content: flex-start;
      overflow-x: auto;
    }

    #sticker-designer-embed .sde-workspace {
      grid-template-columns: 1fr;
    }

    #sticker-designer-embed .sde-side {
      border-right: 0;
      border-bottom: 1px solid var(--sde-line);
    }

    #sticker-designer-embed .sde-side .sde-section {
      display: flex;
      gap: 10px;
      overflow-x: auto;
    }

    #sticker-designer-embed .sde-tool-list {
      display: flex;
      gap: 10px;
    }

    #sticker-designer-embed .sde-stage {
      padding: 18px;
      place-items: start;
    }

    #sticker-designer-embed .sde-contextbar,
    #sticker-designer-embed .sde-status {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>

